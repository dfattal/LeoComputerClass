      {"name": "otp_decrypt([114, 114, 122], [1, 2, 3]) ~ round-trip to spy", "args": [[114, 114, 122], [1, 2, 3]], "expected": "spy"}
    ]
  },
  {
    "entry": "two_time_leak",
    "cases": [
      {"name": "two_time_leak of \"hello\" and \"world\" (same key) ~ key cancels", "args": [[98, 173, 77, 107, 12], [125, 167, 83, 107, 7]], "expected": [31, 10, 30, 0, 11]}
    ]
  }
