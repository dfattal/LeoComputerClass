[
  {
    "entry": "matches",
    "cases": [
      {
        "name": "'10' matches 10.0.0.5",
        "args": [
          "10",
          "10.0.0.5"
        ],
        "expected": true
      },
      {
        "name": "'10.0' matches 10.0.0.5",
        "args": [
          "10.0",
          "10.0.0.5"
        ],
        "expected": true
      },
      {
        "name": "'192.168.1' does not match 10.0.0.5",
        "args": [
          "192.168.1",
          "10.0.0.5"
        ],
        "expected": false
      },
      {
        "name": "the catch-all matches anything",
        "args": [
          "",
          "8.8.8.8"
        ],
        "expected": true
      },
      {
        "name": "'10' does NOT match 100.0.0.1",
        "args": [
          "10",
          "100.0.0.1"
        ],
        "expected": false
      }
    ]
  },
  {
    "entry": "next_hop",
    "cases": [
      {
        "name": "10.0.0.5 takes the most specific road (R2)",
        "args": [
          "10.0.0.5",
          [
            [
              "",
              "R0"
            ],
            [
              "10",
              "R1"
            ],
            [
              "10.0",
              "R2"
            ],
            [
              "192.168.1",
              "R3"
            ]
          ]
        ],
        "expected": "R2"
      },
      {
        "name": "10.9.9.9 falls back to R1",
        "args": [
          "10.9.9.9",
          [
            [
              "",
              "R0"
            ],
            [
              "10",
              "R1"
            ],
            [
              "10.0",
              "R2"
            ],
            [
              "192.168.1",
              "R3"
            ]
          ]
        ],
        "expected": "R1"
      },
      {
        "name": "192.168.1.20 goes to R3",
        "args": [
          "192.168.1.20",
          [
            [
              "",
              "R0"
            ],
            [
              "10",
              "R1"
            ],
            [
              "10.0",
              "R2"
            ],
            [
              "192.168.1",
              "R3"
            ]
          ]
        ],
        "expected": "R3"
      },
      {
        "name": "an unknown address takes the default R0",
        "args": [
          "8.8.8.8",
          [
            [
              "",
              "R0"
            ],
            [
              "10",
              "R1"
            ],
            [
              "10.0",
              "R2"
            ],
            [
              "192.168.1",
              "R3"
            ]
          ]
        ],
        "expected": "R0"
      }
    ]
  },
  {
    "entry": "default_route",
    "cases": [
      {
        "name": "the demo table's default is R0",
        "args": [
          [
            [
              "",
              "R0"
            ],
            [
              "10",
              "R1"
            ],
            [
              "10.0",
              "R2"
            ],
            [
              "192.168.1",
              "R3"
            ]
          ]
        ],
        "expected": "R0"
      },
      {
        "name": "a table with no default returns ''",
        "args": [
          [
            [
              "10",
              "R1"
            ],
            [
              "192.168.1",
              "R3"
            ]
          ]
        ],
        "expected": ""
      }
    ]
  }
]
