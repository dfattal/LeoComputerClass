[
  {
    "entry": "well_known",
    "cases": [
      {
        "name": "80 is the web",
        "args": [
          80
        ],
        "expected": "web"
      },
      {
        "name": "443 is the secure web",
        "args": [
          443
        ],
        "expected": "secure web"
      },
      {
        "name": "22 is login",
        "args": [
          22
        ],
        "expected": "login"
      },
      {
        "name": "53 is dns",
        "args": [
          53
        ],
        "expected": "dns"
      },
      {
        "name": "9999 is unknown",
        "args": [
          9999
        ],
        "expected": "unknown"
      }
    ]
  },
  {
    "entry": "route_to_app",
    "cases": [
      {
        "name": "port 80 -> web",
        "args": [
          80,
          [
