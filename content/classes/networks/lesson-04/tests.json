              "web"
            ],
            [
              443,
              "secure web"
            ]
          ]
        ],
        "expected": "web"
      },
      {
        "name": "port 22 -> login",
        "args": [
          22,
          [
            [
              22,
              "login"
            ],
            [
              80,
              "web"
            ],
            [
              443,
              "secure web"
            ]
          ]
        ],
        "expected": "login"
      },
      {
        "name": "port 443 -> secure web",
        "args": [
          443,
          [
            [
              22,
              "login"
            ],
            [
              80,
              "web"
            ],
            [
              443,
              "secure web"
            ]
          ]
        ],
        "expected": "secure web"
      },
      {
        "name": "port 8080 is closed here",
        "args": [
          8080,
          [
            [
              22,
              "login"
            ],
            [
              80,
              "web"
            ],
            [
              443,
              "secure web"
            ]
          ]
        ],
        "expected": "closed"
      }
